# Rust
target/
# JS/TS
node_modules/
*.tsbuildinfo
# Vite build output (edge desktop frontend) — rebuilt by `make platform-edge-build`
edge/ui/dist/
# Tauri-generated schemas (regenerated by tauri-build each compile)
edge/shell/gen/
# Playwright UI-smoke screenshots (regenerated by `make platform-edge-ui`)
edge/ui/.ui-shots/
# Local edge stores / run logs (never committed)
.surrealdb/
.wagner/
# Deno
deno.lock.tmp
# OS
.DS_Store
# IDE
.idea/
.vscode/
# Staged voice sidecar binaries (build artifacts — not source)
edge/shell/binaries/
# Local rollback backups (global convention; never committed)
.backups/
# Agent worktrees (transient; created by background subagents)
.claude/worktrees/
# Logs
*.log

# CodeGraph local index (tooling)
.codegraph/
