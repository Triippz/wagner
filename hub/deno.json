{
  "name": "@wagner/hub",
  "version": "0.0.0",
  "exports": "./src/main.ts",
  "tasks": {
    "dev": "deno run -A --watch src/main.ts",
    "test": "deno test -A --no-check=remote"
  },
  "lock": false,
  "imports": {
    "@wagner/shared/": "../shared/",
    "hono": "jsr:@hono/hono@^4.6.14",
    "jose": "npm:jose@^5.9.6",
    "@std/assert": "jsr:@std/assert@^1.0.8",
    "loro-crdt": "npm:loro-crdt@^1",
    "@std/encoding/base64": "jsr:@std/encoding@^1/base64"
  },
  "compilerOptions": {
    "strict": true,
    "lib": ["deno.window", "esnext"]
  },
  "fmt": {
    "lineWidth": 100,
    "semiColons": true
  }
}
