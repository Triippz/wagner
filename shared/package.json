{
  "name": "@wagner/shared",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Carried spine: canonical JSON Schemas + pure reducers (UI projection + event-sourced run spine). No I/O, no UI dependency.",
  "exports": {
    "./reducer": "./reducer/index.ts",
    "./reducer/remote-reducer": "./reducer/remote-reducer.ts",
    "./reducer/remote-events": "./reducer/remote-events.ts",
    "./run-reducer": "./reducer/run-reducer.ts",
    "./run-events": "./reducer/run-events.ts",
    "./transport": "./transport/index.ts",
    "./schemas/*": "./schemas/*"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json",
    "gen:contracts": "json2ts -i '../edge/host/schemas/bus/*.json' -o contracts && node scripts/contracts-barrel.mjs"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "ajv": "^8.17.1",
    "json-schema-to-typescript": "^15.0.0"
  }
}
