{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RemoteAttach",
  "description": "Client attach handshake — client joins an armed remote session.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "operator_id",
    "client_id",
    "ticket_id",
    "ts"
  ],
  "properties": {
    "schema": {
      "const": "remote-attach.v1"
    },
    "operator_id": {
      "type": "string",
      "minLength": 1
    },
    "client_id": {
      "type": "string",
      "minLength": 1
    },
    "ticket_id": {
      "type": "string",
      "minLength": 1
    },
    "ts": {
      "type": "string",
      "format": "date-time"
    }
  }
}
