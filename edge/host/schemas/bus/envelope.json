{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Envelope",
  "description": "The unit carried by the bus: a typed `Event` payload wrapped with identity,\nordering, and scope (FR-001/FR-002). `stream` + monotonic `seq` make\nper-stream ordering expressible (enforcement is `011` P1).",
  "type": "object",
  "properties": {
    "schema": {
      "description": "Schema-version id (FR-016) — always `\"envelope.v1\"` for this version.",
      "type": "string"
    },
    "id": {
      "$ref": "#/$defs/EventId"
    },
    "ts": {
      "$ref": "#/$defs/Timestamp"
    },
    "origin": {
      "$ref": "#/$defs/ParticipantId"
    },
    "stream": {
      "$ref": "#/$defs/StreamId"
    },
    "seq": {
      "type": "integer",
      "format": "uint64",
      "minimum": 0
    },
    "scope": {
      "$ref": "#/$defs/Scope"
    },
    "payload": {
      "$ref": "#/$defs/Event"
    }
  },
  "additionalProperties": false,
  "required": [
    "schema",
    "id",
    "ts",
    "origin",
    "stream",
    "seq",
    "scope",
    "payload"
  ],
  "$defs": {
    "EventId": {
      "description": "A unique, sortable event id (ULID), serialized as a Crockford-base32 string.",
      "type": "string"
    },
    "Timestamp": {
      "description": "An RFC 3339 timestamp. Carried as a string at the contract boundary; parsed\nto a calendar type only where a consumer needs ordering (`011`).",
      "type": "string"
    },
    "ParticipantId": {
      "description": "Stable identity of a participant (FR-003): which peer/machine, what kind, a\nstable logical name, and a per-instance id.",
      "type": "object",
      "properties": {
        "node": {
          "description": "The peer/machine identity (iroh node id, z-base-32).",
          "$ref": "#/$defs/NodeId"
        },
        "kind": {
          "$ref": "#/$defs/ParticipantKind"
        },
        "name": {
          "description": "A stable logical name (e.g. `\"goal-loop\"`, `\"slack-connector\"`).",
          "type": "string"
        },
        "instance": {
          "description": "Distinguishes two live instances of the same logical name.",
          "type": "string"
        }
      },
      "additionalProperties": false,
      "required": [
        "node",
        "kind",
        "name",
        "instance"
      ]
    },
    "NodeId": {
      "description": "An iroh node identity in its canonical z-base-32 string form. The contract\ncarries the identity as a string; it is parsed to `iroh::NodeId` at the\nintake boundary (`011` P3), where peer identity is actually authorized.",
      "type": "string"
    },
    "ParticipantKind": {
      "description": "The kind of participant behind a [`ParticipantId`].",
      "type": "string",
      "enum": [
        "goal_loop",
        "agent",
        "connector",
        "scheduler",
        "ui",
        "system"
      ]
    },
    "StreamId": {
      "description": "The ordering scope of an event (FR-005). `Run` is the common case; new kinds\nare added additively.",
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "run"
            },
            "data": {
              "type": "string"
            }
          },
          "required": [
            "type",
            "data"
          ],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "agent"
            },
            "data": {
              "type": "string"
            }
          },
          "required": [
            "type",
            "data"
          ],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "workspace"
            },
            "data": {
              "type": "string"
            }
          },
          "required": [
            "type",
            "data"
          ],
          "additionalProperties": false
        }
      ]
    },
    "Scope": {
      "description": "The multi-tenant filter seam (FR-004) — exactly `{user, workspace}` in v1; an\norg tier or further fields are added additively when multi-tenant lands.",
      "type": "object",
      "properties": {
        "user": {
          "type": "string"
        },
        "workspace": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "required": [
        "user",
        "workspace"
      ]
    },
    "Event": {
      "description": "A namespaced, past-tense fact carried by the bus. Adjacently tagged as\n`{ \"type\": <namespace>, \"data\": <leaf> }`. The namespace set is the **stable\nstructure**; leaf variants land additively inside each namespace enum without\nediting this core (FR-006).",
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "run"
            },
            "data": {
              "$ref": "#/$defs/RunEvent"
            }
          },
          "required": [
            "type",
            "data"
          ],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "goal"
            },
            "data": {
              "$ref": "#/$defs/GoalEvent"
            }
          },
          "required": [
            "type",
            "data"
          ],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "vault"
            },
            "data": {
              "$ref": "#/$defs/VaultEvent"
            }
          },
          "required": [
            "type",
            "data"
          ],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "voice"
            },
            "data": {
              "$ref": "#/$defs/VoiceEvent"
            }
          },
          "required": [
            "type",
            "data"
          ],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "ui"
            },
            "data": {
              "$ref": "#/$defs/UiEvent"
            }
          },
          "required": [
            "type",
            "data"
          ],
          "additionalProperties": false
        },
        {
          "description": "Extension fact in a plugin-owned namespace; `payload` validates against\nthe schema registered for `{ns, name, version}` (FR-009).",
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "ext"
            },
            "data": {
              "type": "object",
              "properties": {
                "ns": {
                  "type": "string"
                },
                "name": {
                  "type": "string"
                },
                "version": {
                  "type": "integer",
                  "format": "uint32",
                  "minimum": 0
                },
                "payload": true
              },
              "additionalProperties": false,
              "required": [
                "ns",
                "name",
                "version",
                "payload"
              ]
            }
          },
          "required": [
            "type",
            "data"
          ],
          "additionalProperties": false
        }
      ]
    },
    "RunEvent": {
      "description": "Run-namespace facts. The migrated `wagner://*` run-execution channels land\nhere (P2): the bus carries the real payloads so the `UiGateway` can re-emit\nthe legacy Tauri events byte-identically.",
      "oneOf": [
        {
          "description": "`run.finished` — a run reached a terminal state (seed; `Snapshot` carries\nthe full live + terminal state for the UI).",
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "finished"
            },
            "data": {
              "type": "object",
              "properties": {
                "run_id": {
                  "type": "string"
                },
                "ok": {
                  "type": "boolean"
                }
              },
              "additionalProperties": false,
              "required": [
                "run_id",
                "ok"
              ]
            }
          },
          "required": [
            "type",
            "data"
          ],
          "additionalProperties": false
        },
        {
          "description": "`wagner://run` — full run-state snapshot (live progress + terminal).",
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "snapshot"
            },
            "data": {
              "$ref": "#/$defs/Run"
            }
          },
          "required": [
            "type",
            "data"
          ],
          "additionalProperties": false
        },
        {
          "description": "`wagner://event` — operative floor activity during a run.",
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "activity"
            },
            "data": {
              "$ref": "#/$defs/WagnerEvent"
            }
          },
          "required": [
            "type",
            "data"
          ],
          "additionalProperties": false
        },
        {
          "description": "`wagner://transmission` — a gate/permission prompt awaiting a human answer.",
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "transmission"
            },
            "data": true
          },
          "required": [
            "type",
            "data"
          ],
          "additionalProperties": false
        },
        {
          "description": "`wagner://workflow` — a workflow step record.",
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "workflow_step"
            },
            "data": true
          },
          "required": [
            "type",
            "data"
          ],
          "additionalProperties": false
        },
        {
          "description": "`wagner://workflow-done` — terminal workflow summary.",
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "workflow_done"
            },
            "data": true
          },
          "required": [
            "type",
            "data"
          ],
          "additionalProperties": false
        }
      ]
    },
    "Run": {
      "type": "object",
      "properties": {
        "schema": {
          "type": "string"
        },
        "run_id": {
          "type": "string"
        },
        "goal": {
          "type": "string"
        },
        "docs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "status": {
          "$ref": "#/$defs/RunStatus"
        },
        "phase": {
          "description": "Fine-grained live step (mission bar). Not persisted-critical; defaults to Idle.",
          "$ref": "#/$defs/RunPhase",
          "default": "idle"
        },
        "iteration": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0,
          "default": 0
        },
        "guardrails": {
          "$ref": "#/$defs/Guardrails"
        },
        "created_at": {
          "type": "string"
        },
        "halt_reason": {
          "anyOf": [
            {
              "$ref": "#/$defs/HaltReason"
            },
            {
              "type": "null"
            }
          ]
        },
        "subtasks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Subtask"
          },
          "default": []
        },
        "transmissions": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "console_inputs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ConsoleInput"
          },
          "default": []
        },
        "project_dir": {
          "description": "The on-disk project directory the session's agents run in. Persisted so a\nclosed session can be resumed (the pool is rebuilt against this cwd).\nEmpty on legacy runs created before sessions existed.",
          "type": "string",
          "default": ""
        },
        "name": {
          "description": "Human-readable session label for the rail (defaults to the folder name).",
          "type": "string",
          "default": ""
        },
        "updated_at": {
          "description": "Last-saved timestamp — drives the session rail's newest-first ordering.\nDefaults to `created_at` for legacy runs.",
          "type": "string",
          "default": ""
        },
        "goals": {
          "description": "The session's goal thread — append-only. Seeded with the first goal at\ncreation; `add_goal` appends and reactivates the session.",
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        }
      },
      "required": [
        "schema",
        "run_id",
        "goal",
        "status",
        "guardrails",
        "created_at"
      ]
    },
    "RunStatus": {
      "type": "string",
      "enum": [
        "drafted",
        "running",
        "met",
        "halted_guardrail",
        "aborted",
        "paused"
      ]
    },
    "RunPhase": {
      "description": "The fine-grained step the loop is in — surfaced live so the mission bar can\nshow \"what's happening right now\" beyond the coarse `RunStatus`.",
      "type": "string",
      "enum": [
        "idle",
        "planning",
        "dispatching",
        "judging",
        "blocked",
        "met",
        "halted"
      ]
    },
    "Guardrails": {
      "type": "object",
      "properties": {
        "max_iterations": {
          "description": "Optional runaway-loop cap. `None` = run until goal-met (cost + blocked\ntimeout remain the brakes).",
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "minimum": 0
        },
        "iterations_used": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0,
          "default": 0
        },
        "blocked_timeout_secs": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        },
        "cost": {
          "$ref": "#/$defs/CostBudget"
        }
      },
      "required": [
        "blocked_timeout_secs",
        "cost"
      ]
    },
    "CostBudget": {
      "type": "object",
      "properties": {
        "mode": {
          "$ref": "#/$defs/CostMode"
        },
        "budget": {
          "type": [
            "number",
            "null"
          ],
          "format": "double"
        },
        "used": {
          "type": "number",
          "format": "double",
          "default": 0.0
        }
      },
      "required": [
        "mode"
      ]
    },
    "CostMode": {
      "oneOf": [
        {
          "description": "Usage reported by the CLI itself (preferred when available).",
          "type": "string",
          "const": "cli_usage"
        },
        {
          "description": "Wall-clock fallback when a CLI exposes no usage signal (FR-015).",
          "type": "string",
          "const": "wallclock"
        }
      ]
    },
    "HaltReason": {
      "oneOf": [
        {
          "type": "string",
          "enum": [
            "iterations",
            "cost",
            "blocked_timeout"
          ]
        },
        {
          "description": "The run was launched in an unusable state (e.g. no lead-capable agent in\nthe roster). Surfaced as a terminal halt instead of panicking the loop.",
          "type": "string",
          "const": "misconfigured"
        }
      ]
    },
    "Subtask": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "agent_id": {
          "description": "The hired-roster agent id this subtask was dispatched to.",
          "type": "string"
        },
        "assignment_rationale": {
          "type": [
            "string",
            "null"
          ]
        },
        "prompt": {
          "type": "string"
        },
        "state": {
          "$ref": "#/$defs/SubtaskState"
        },
        "worktree": {
          "type": [
            "string",
            "null"
          ]
        },
        "result_summary": {
          "type": [
            "string",
            "null"
          ]
        },
        "parent_event_ids": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        }
      },
      "required": [
        "id",
        "agent_id",
        "prompt",
        "state"
      ]
    },
    "SubtaskState": {
      "type": "string",
      "enum": [
        "queued",
        "running",
        "done",
        "failed"
      ]
    },
    "ConsoleInput": {
      "type": "object",
      "properties": {
        "ts": {
          "type": "string"
        },
        "text": {
          "type": "string"
        }
      },
      "required": [
        "ts",
        "text"
      ]
    },
    "WagnerEvent": {
      "description": "The normalized event emitted to the frontend.",
      "type": "object",
      "properties": {
        "schema": {
          "type": "string"
        },
        "event_id": {
          "type": "string"
        },
        "run_id": {
          "type": "string"
        },
        "operative_id": {
          "type": "string"
        },
        "operative_name": {
          "description": "Display name of the hired agent (floor label). Defaults to the id.",
          "type": "string",
          "default": ""
        },
        "faction": {
          "$ref": "#/$defs/Faction"
        },
        "activity": {
          "$ref": "#/$defs/Activity"
        },
        "district": {
          "$ref": "#/$defs/District"
        },
        "state": {
          "$ref": "#/$defs/OperativeState"
        },
        "message": {
          "type": [
            "string",
            "null"
          ]
        },
        "handoff_target_operative_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "ts": {
          "type": "string"
        }
      },
      "required": [
        "schema",
        "event_id",
        "run_id",
        "operative_id",
        "faction",
        "activity",
        "district",
        "state",
        "ts"
      ]
    },
    "Faction": {
      "description": "Which engine an operative belongs to.",
      "type": "string",
      "enum": [
        "architects",
        "forgers"
      ]
    },
    "Activity": {
      "description": "The kind of work an operative is doing right now. Drives district + state.",
      "type": "string",
      "enum": [
        "read",
        "edit",
        "test",
        "build",
        "lint",
        "shell",
        "review",
        "diff",
        "judge",
        "plan",
        "decompose",
        "think",
        "await_permission",
        "await_question"
      ]
    },
    "District": {
      "description": "One of the five zones on the operations floor.",
      "type": "string",
      "enum": [
        "stacks",
        "forge",
        "mirror",
        "oracle",
        "gate"
      ]
    },
    "OperativeState": {
      "description": "The state ring shown around an operative.",
      "type": "string",
      "enum": [
        "idle",
        "thinking",
        "working",
        "blocked"
      ]
    },
    "GoalEvent": {
      "description": "Goal-namespace facts.",
      "oneOf": [
        {
          "description": "`goal.added` — a goal entered the backlog.",
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "added"
            },
            "data": {
              "type": "object",
              "properties": {
                "goal_id": {
                  "type": "string"
                },
                "title": {
                  "type": "string"
                }
              },
              "additionalProperties": false,
              "required": [
                "goal_id",
                "title"
              ]
            }
          },
          "required": [
            "type",
            "data"
          ],
          "additionalProperties": false
        }
      ]
    },
    "VaultEvent": {
      "description": "Vault-namespace facts.",
      "oneOf": [
        {
          "description": "`vault.note_updated` — a note's contents changed.",
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "note_updated"
            },
            "data": {
              "type": "object",
              "properties": {
                "path": {
                  "type": "string"
                },
                "rev": {
                  "type": "integer",
                  "format": "uint64",
                  "minimum": 0
                }
              },
              "additionalProperties": false,
              "required": [
                "path",
                "rev"
              ]
            }
          },
          "required": [
            "type",
            "data"
          ],
          "additionalProperties": false
        }
      ]
    },
    "VoiceEvent": {
      "description": "Voice-namespace facts.",
      "oneOf": [
        {
          "description": "`voice.utterance_transcribed` — STT produced text for an utterance.",
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "utterance_transcribed"
            },
            "data": {
              "type": "object",
              "properties": {
                "text": {
                  "type": "string"
                }
              },
              "additionalProperties": false,
              "required": [
                "text"
              ]
            }
          },
          "required": [
            "type",
            "data"
          ],
          "additionalProperties": false
        },
        {
          "description": "`wagner://voice-download` — model download progress.",
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "download_progress"
            },
            "data": {
              "$ref": "#/$defs/ModelProgress"
            }
          },
          "required": [
            "type",
            "data"
          ],
          "additionalProperties": false
        }
      ]
    },
    "ModelProgress": {
      "description": "A single progress event emitted by `download_models`.\n\nSerialised by the shell into the `wagner://voice-download` Tauri event with\nkeys `model` / `state` / `received` / `total` (camelCase intentionally not\napplied — the UI lane's contract uses these exact names).",
      "type": "object",
      "properties": {
        "model": {
          "description": "Model id (matches `ModelDef::id`): `\"stt\"` | `\"tts_model\"` | `\"tts_voices\"`.",
          "type": "string"
        },
        "state": {
          "$ref": "#/$defs/ModelState"
        },
        "received": {
          "description": "Bytes received so far.",
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        },
        "total": {
          "description": "Total bytes expected (`0` when unknown until download completes).",
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        }
      },
      "required": [
        "model",
        "state",
        "received",
        "total"
      ]
    },
    "ModelState": {
      "description": "Persistent disk state visible to `models_status`. Transient states\n(`Downloading`, `Verifying`) are not stored — they only appear in live\n`ModelProgress` callbacks.",
      "type": "string",
      "enum": [
        "absent",
        "downloading",
        "verifying",
        "ready",
        "failed"
      ]
    },
    "UiEvent": {
      "description": "UI-namespace facts.",
      "oneOf": [
        {
          "description": "`ui.surface_focused` — a workspace surface gained focus.",
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "surface_focused"
            },
            "data": {
              "type": "object",
              "properties": {
                "surface": {
                  "type": "string"
                }
              },
              "additionalProperties": false,
              "required": [
                "surface"
              ]
            }
          },
          "required": [
            "type",
            "data"
          ],
          "additionalProperties": false
        },
        {
          "description": "`wagner://panel` — an agent-authored UI spec panel. `spec` is arbitrary\nagent JSON by design (the panel DSL), so it stays a `Value`.",
