{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "voice-sidecars",
  "description": "Least-privilege shell execution for the voice sidecars only",
  "windows": ["main"],
  "permissions": [
    "shell:allow-spawn",
    "shell:allow-kill",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        { "name": "whisper-server", "sidecar": true },
        { "name": "wagner-tts-sidecar", "sidecar": true }
      ]
    }
  ]
}
