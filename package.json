{
  "name": "@wagner/platform",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Wagner personal OS — local-first agents, workflows, vault knowledge graph, edge UI, and hub sync.",
  "workspaces": [
    "shared",
    "edge/ui",
    "tests/architecture"
  ],
  "scripts": {
